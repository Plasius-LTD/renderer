{
  "name": "@plasius/renderer",
  "version": "1.0.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "description": "3D rendering package for Plasius projects with XR integration hooks",
  "scripts": {
    "build": "tsc --build --listEmittedFiles && (rsync -av --include '*/' --include '*.module.css' --include '*.js' --exclude '*' src/ dist/ || true)",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "reset:clean": "rm -rf node_modules package-lock.json && npm run clean",
    "audit:ts": "tsc --noEmit --pretty",
    "audit:eslint": "eslint . --max-warnings=0",
    "audit:deps": "npm ls --all --omit=optional --omit=peer > /dev/null 2>&1 || true",
    "audit:npm": "npm audit --audit-level=high --omit=dev",
    "audit:test": "vitest run --coverage",
    "audit:all": "npm-run-all -l audit:ts audit:eslint audit:deps audit:npm audit:test",
    "lint": "eslint . --max-warnings=0",
    "prepare": "npm run build",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "author": "Plasius LTD <development@plasius.co.uk>",
  "license": "Apache-2.0",
  "peerDependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.1.2",
    "@react-three/fiber": "^9.1.2",
    "@react-three/rapier": "^2.1.0",
    "@react-three/xr": "^6.6.20",
    "react": "^19.1.0",
    "react-icons": "^5.5.0",
    "three": "^0.178.0",
    "three-mesh-bvh": "^0.9.1"
  },
  "devDependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.1.2",
    "@react-three/fiber": "^9.1.2",
    "@react-three/rapier": "^2.1.0",
    "@react-three/xr": "^6.6.20",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^6.12.6",
    "eslint": "^9.33.0",
    "globals": "^17.6.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.1.0",
    "react-icons": "^5.5.0",
    "rimraf": "^6.0.1",
    "three": "^0.178.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.0.17"
  },
  "dependencies": {
    "@plasius/react-state": "^1.2.1",
    "react-icons": "^5.5.0",
    "@plasius/gpu-xr": "^0.1.0",
    "@plasius/gpu-camera": "^0.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "private": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTORS.md",
    "docs",
    "legal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/renderer.git"
  },
  "bugs": {
    "url": "https://github.com/Plasius-LTD/renderer/issues"
  },
  "homepage": "https://github.com/Plasius-LTD/renderer#readme",
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/c/plasiusltd/membership"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/Plasius-LTD"
    }
  ],
  "engines": {
    "node": ">=22.12"
  }
}
